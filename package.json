{
  "name": "financeflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "migration:run": "npm run migration:run --workspace=apps/api",
    "migration:revert": "npm run migration:revert --workspace=apps/api",
    "migration:show": "npm run migration:show --workspace=apps/api",
    "seed:demo": "npm run seed:demo --workspace=apps/api",
    "test": "npm run test --workspace=apps/api",
    "test:api": "npm run test --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web"
  }
}
