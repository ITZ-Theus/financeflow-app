# apps/api/.env
PORT=3333
NODE_ENV=development
JWT_SECRET=troque_esta_chave_em_producao
JWT_EXPIRES_IN=7d
WEB_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5433
DB_USER=financeflow
DB_PASS=financeflow123
DB_NAME=financeflow
DATABASE_URL=
DB_SSL=false
DB_MIGRATIONS_RUN=false
DEMO_SEED_ON_STARTUP=false
DEMO_USER_EMAIL=demo@financeflow.dev
DEMO_USER_PASSWORD=FinanceFlow@2026
BODY_LIMIT=1mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
LOG_LEVEL=debug

# Render, Neon and Supabase commonly expose DATABASE_URL.
# Set DB_SSL=true when your managed Postgres provider requires SSL.
# Set DB_MIGRATIONS_RUN=true when you want the API to run pending migrations on startup.
# AUTH_RATE_LIMIT_* controls brute-force protection for authentication routes.
# LOG_LEVEL supports pino levels such as debug, info, warn, error and silent.

# apps/web/.env
VITE_API_URL=http://localhost:3333/api
VITE_DEMO_EMAIL=demo@financeflow.dev
VITE_DEMO_PASSWORD=FinanceFlow@2026
